# ────────────────────────────────────────────────────────────
# OS / editor (always apply)
# ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ────────────────────────────────────────────────────────────
# Secrets & env (always apply)
# ────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ────────────────────────────────────────────────────────────
# Logs (always apply)
# ────────────────────────────────────────────────────────────
logs/
*.log

# ────────────────────────────────────────────────────────────
# Build outputs (generic)
# ────────────────────────────────────────────────────────────
dist/
build/
out/
.cache/

# ────────────────────────────────────────────────────────────
# Bun / TypeScript (toolchain locked)
# ────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# TypeScript incremental build cache
*.tsbuildinfo

# Test coverage
coverage/

# Note: bun.lock IS committed (lockfile). Do not ignore it.

# ────────────────────────────────────────────────────────────
# notify-bus runtime data (never commit state)
# ────────────────────────────────────────────────────────────

# SQLite database + WAL sidecars (bun:sqlite, WAL mode)
data/
*.db
*.db-wal
*.db-shm

# Local config (the example is committed, local is not)
config.yaml

# Built frontend (regenerated by `bun run build:web`)
packages/web/dist/

# ────────────────────────────────────────────────────────────
# Frontend tooling (packages/web/)
# ────────────────────────────────────────────────────────────
packages/web/.vite/
