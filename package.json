{
  "name": "notify-bus",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Self-hostable multi-channel notification bus. GitHub webhooks in, Feishu (and more) out. Bun + Elysia + React.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green 'bun run --watch packages/server/src/index.ts' 'bun --cwd packages/web run dev'",
    "dev:server": "bun run --watch packages/server/src/index.ts",
    "dev:web": "bun --cwd packages/web run dev",
    "build": "bun run build:web",
    "build:web": "bun --cwd packages/web run build",
    "start": "bun run packages/server/src/index.ts",
    "test": "bun test",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "oxlint": "1.73.0",
    "oxfmt": "0.58.0",
    "concurrently": "^9.0.0"
  }
}
