# ────────────────────────────────────────────────────────────
# notify-bus environment
# Copy to .env and fill in. .env is gitignored.
# ────────────────────────────────────────────────────────────

# Host port to expose the service on (loopback only — docker-compose binds
# 127.0.0.1, not 0.0.0.0). Pick a non-obvious port and front it with a reverse
# proxy (nginx/caddy) that terminates TLS. The container itself always listens
# on 3000 internally; this maps host:127.0.0.1:PORT -> container:3000.
PORT=3000

# GitHub webhook secret. Used to verify the HMAC-SHA256 signature on
# POST /webhook (X-Hub-Signature-256 header). Must match the secret set on
# the webhook in your GitHub repo settings. NEVER commit this.
GITHUB_WEBHOOK_SECRET=

# Directory holding the SQLite database. Mount this as a volume in Docker.
# Default: ./data  (the directory is created if missing)
DATA_DIR=./data

# Path to the YAML seed config. Default: ./config.yaml
# The example is committed as config.example.yaml; copy to config.yaml.
CONFIG_PATH=./config.yaml

# Path to the built frontend (served by the server's static plugin).
# Leave empty for local dev (defaults to ../web/dist relative to the server).
# Docker sets this to /app/web-dist.
WEB_DIST_PATH=

# Environment. "production" disables some dev affordances.
NODE_ENV=development
